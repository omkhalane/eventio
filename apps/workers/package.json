{
  "name": "@eventio/workers",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "start": "tsx --env-file=../../.env src/index.ts",
    "start:scheduler": "tsx --env-file=../../.env src/scheduler.ts",
    "scrape:trigger": "tsx --env-file=../../.env src/scripts/triggerScraper.ts",
    "scrape:run": "tsx --env-file=../../.env src/scripts/runScrapers.ts",
    "scrape:run:ci": "tsx src/scripts/runScrapers.ts",
    "scrape:temp": "tsx --env-file=../../.env ../../temp/scraperRunner.ts"
  },
  "dependencies": {
    "@eventio/db": "workspace:*",
    "@eventio/queue": "workspace:*",
    "@eventio/observability": "workspace:*",
    "@eventio/scraper-core": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
