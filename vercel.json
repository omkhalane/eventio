{
  "functions": {
    "api/v1/index.ts": {
      "runtime": "vercel-node@5.8.1"
    },
    "api/config.ts": {
      "runtime": "vercel-node@5.8.1"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/index.ts"
    },
    {
      "source": "/api/config",
      "destination": "/api/config.ts"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
