{
  "name": "eventio-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "build": "pnpm --recursive run build",
    "test": "pnpm --recursive run test",
    "lint": "pnpm --recursive run lint",
    "db:push": "pnpm --filter @eventio/db run db:push",
    "db:generate": "pnpm --filter @eventio/db run db:generate",
    "scrape:trigger": "pnpm --filter @eventio/workers run scrape:trigger",
    "scrape:run": "pnpm --filter @eventio/workers run scrape:run",
    "scrape:temp": "pnpm --filter @eventio/workers run scrape:temp",
    "check": "pnpm run lint"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "eslint": "^9.0.0",
    "@vercel/node": "^5.0.0"
  },
  "version": "1.0.0"
}
