{
  "name": "eventio",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "version": "0.0.0",
  "type": "module",
  "author": {
    "name": "Om Khalane",
    "email": "om.khalane.dev@gmail.com",
    "url": "https://github.com/omkhalane"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omkhalane/eventio.git"
  },
  "homepage": "https://eventio-sandy.vercel.app/",
  "bugs": {
    "url": "https://github.com/omkhalane/eventio/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "dev:server": "tsx apps/web/server.ts",
    "build": "vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts --host 0.0.0.0",
    "start": "NODE_ENV=production tsx apps/web/server.ts",
    "clean": "rm -rf dist apps/web/.vite .cache .pytest_cache htmlcov coverage",
    "typecheck": "tsc --noEmit",
    "scraper:list": "python3 -m services.scraper.main --list",
    "scraper:check": "python3 -m compileall services/scraper",
    "check": "npm run typecheck && npm run scraper:check",
    "lint": "npm run check"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@supabase/supabase-js": "^2.105.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/google.accounts": "^0.0.18",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.12.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}
