# Eventio environment template.
# Values named PUBLIC_* are served from /api/config and are visible to users.
# Never put private keys, Neon URLs, Redis URLs, passwords, or service keys in PUBLIC_* variables.

# Neon/Postgres server-only database URLs.
# DATABASE_URL should use the pooled Neon URL for runtime.
# DIRECT_DATABASE_URL should use the direct Neon URL for migrations/setup.
DATABASE_URL=
DIRECT_DATABASE_URL=

# Redis server-only queue URL for BullMQ workers.
REDIS_URL=

# Firebase public web app config
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_APP_ID=your_app_id
PUBLIC_FIREBASE_API_KEY=your_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID=your_firestore_database_id

# Server
NODE_ENV=development
PORT=3000
API_HOST=localhost
API_PORT=3000
LOG_LEVEL=debug
DISABLE_HMR=false

# Optional public analytics.
# Browser-readable project identifier, not a private secret.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
