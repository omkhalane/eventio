################################################################################
# EVENTIO - Environment Configuration Template
# 
# This file contains all environment variables needed to run Eventio in
# development, staging, and production environments.
# 
# DO NOT commit .env with real credentials. Use .env.local for sensitive data.
################################################################################

# ============================================================================
# CORE APPLICATION SETTINGS
# ============================================================================

# Environment: development, staging, production
NODE_ENV=development

# Frontend Server
HOST=0.0.0.0
PORT=5175

# API Server
API_HOST=localhost
API_PORT=3000

# Logging level: debug, info, warn, error
LOG_LEVEL=debug

# ============================================================================
# PUBLIC URLS (Visible to Frontend)
# ============================================================================

# Production site URL (used for SEO, canonical URLs, CORS)
PUBLIC_SITE_URL=https://event-io.me

# API base URL (frontend makes requests to this)
PUBLIC_API_BASE_URL=https://event-io.me

# ============================================================================
# DATABASE & CACHE (Server-Only)
# ============================================================================

# PostgreSQL connection string (use pooled connection for production)
# Example: postgresql://user:password@host:5432/eventio?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventio

# Direct connection URL (for migrations only, not runtime)
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventio

# Redis connection details (for BullMQ queues and caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# API KEYS & AUTHENTICATION (Server-Only, Keep Secret)
# ============================================================================

# Public API keys (comma or newline separated)
# Example: key1,key2,key3
PUBLIC_API_KEYS=

# Internal API keys (for admin/server access)
# Example: internal_key_1\ninternal_key_2
INTERNAL_API_KEYS=

# Rate limiting (requests per minute)
PUBLIC_RATE_LIMIT_PER_MINUTE=120
ANONYMOUS_RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# OPTIONAL INTEGRATIONS - Public (Browser-Readable)
# ============================================================================

# Firebase Configuration
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_FIRESTORE_DATABASE_ID=

# Analytics
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# DEPLOYMENT & INFRASTRUCTURE
# ============================================================================

# Docker/Container settings
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# Sentry (Error tracking) - Optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# FEATURE FLAGS
# ============================================================================

DISABLE_HMR=false
ENABLE_ANALYTICS=true
ENABLE_ERROR_TRACKING=false
